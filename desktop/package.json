{
  "name": "studyos-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Native desktop shell for TaskHub / StudyOS — adds true OS file drag-out into any app (Claude, Explorer, etc.)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.anthonyn99.studyos",
    "productName": "TaskHub",
    "files": ["main.js", "preload.js", "drag-icon.png"],
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
