rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reminder docs — written by the client (anonymous auth) and read/cleaned
    // by the Cloud Worker (service account bypasses rules). THIS match was
    // missing, so client writes to /reminders were default-denied and no push
    // ever fired on any device.
    match /reminders/{id} {
      allow read, write: if request.auth != null;
    }

    // Device push tokens (this one already worked).
    match /fcm_tokens/{id} {
      allow read, write: if request.auth != null;
    }

    // App data (Tony + Veda dashboards, journals, links, etc.)
    match /dashboards/{doc=**} {
      allow read, write: if request.auth != null;
    }

    // Insight (personal finance) — dashboards/insight + subcollections:
    //   plaid_transactions/  — written by the insight-api worker (service
    //                          account bypasses rules); the UI treats
    //                          source:'plaid' docs as strictly read-only
    //   accounts/            — live balances, worker-written
    //   manual_transactions/ — client-editable (manual + CSV imports)
    // Covered by the /dashboards catch-all above (auth-gated). NOTE: because
    // overlapping matches OR together, a stricter client-write ban here would
    // be moot while the catch-alls exist — full rules-level hardening is the
    // step-7 security pass, alongside the app-lock gate.

    // Anything else still requires auth — keeps your hardened posture intact.
    // NOTE: StudyOS documents (incl. file metadata: name/size/mime/storageUrl)
    // live under this catch-all, so the cross-device file sync needs no
    // dedicated Firestore rule. The file *blobs* are NOT in Firebase (Storage
    // needs the paid Blaze plan) — they live in Cloudflare Workers KV via the
    // free `studyos-files` worker (workers/studyos-files).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
